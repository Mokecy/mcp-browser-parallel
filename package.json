    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "playwright",
    "browser",
    "parallel",
    "testing",
    "automation",
    "multi-instance",
    "isolated",
    "chrome",
    "cdp"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "playwright": "1.59.0-alpha-2026-03-24"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
